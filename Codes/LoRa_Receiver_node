
#include <SPI.h>
#include <LoRa.h>
#include "BluetoothSerial.h"

BluetoothSerial BT;

/* PINS */

#define SS 5
#define RST 27
#define DIO0 26
#define BAND 433E6

#define DEVICE_ID 2
#define MASTER_ID 1
#define BROADCAST_ID 255

/* MESSAGE TYPES */

#define MSG_TEXT 1
#define MSG_ACK 2
#define MSG_SLEEP 3
#define MSG_WAKE 4

bool nodeSleeping = false;

byte msgID = 0;
byte lastMsgID = 0;

bool waitingAck = false;
bool masterOnline = true;

unsigned long sendTime = 0;

String inputString = "";

/* PRINT FUNCTIONS */

void logPrint(String s){
Serial.print(s);
BT.print(s);
}

void logPrintln(String s){
Serial.println(s);
BT.println(s);
}

/* SETUP */

void setup(){

Serial.begin(115200);

BT.begin("LoRa_NODE");

SPI.begin(18,19,23,5);
LoRa.setPins(SS,RST,DIO0);

if(!LoRa.begin(BAND)){
Serial.println("LoRa init failed");
while(1);
}

LoRa.enableCrc();
LoRa.receive();

logPrintln("NODE READY");
}

/* SEND MESSAGE */

void sendMessage(String msg){

msgID++;

lastMsgID = msgID;
waitingAck = true;
sendTime = millis();

LoRa.beginPacket();
LoRa.write(MASTER_ID);
LoRa.write(DEVICE_ID);
LoRa.write(MSG_TEXT);
LoRa.write(msgID);
LoRa.write(msg.length());
LoRa.print(msg);
LoRa.endPacket();

logPrint("You: ");
logPrintln(msg);
}

/* RECEIVE MESSAGE */

void receiveMessage(){

int packetSize = LoRa.parsePacket();
if(!packetSize) return;

byte recipient = LoRa.read();
byte sender = LoRa.read();
byte type = LoRa.read();
byte id = LoRa.read();
byte len = LoRa.read();

if(recipient != DEVICE_ID && recipient != BROADCAST_ID) return;

/* TEXT MESSAGE FROM MASTER */

if(type == MSG_TEXT && !nodeSleeping){

String msg = "";

while(LoRa.available()){
msg += (char)LoRa.read();
}

logPrint("Master: ");
logPrintln(msg);

Serial.print("Signal RSSI: ");
Serial.println(LoRa.packetRssi());

/* SEND ACK BACK */

LoRa.beginPacket();
LoRa.write(sender);
LoRa.write(DEVICE_ID);
LoRa.write(MSG_ACK);
LoRa.write(id);
LoRa.write(0);
LoRa.endPacket();
}

/* ACK RECEIVED */

else if(type == MSG_ACK){

if(waitingAck && id == lastMsgID){

waitingAck = false;

if(!masterOnline){
masterOnline = true;
logPrintln("Node is online now. Communication restored.");
}

logPrintln("✓ Delivered");
}

}

/* SLEEP COMMAND */

else if(type == MSG_SLEEP){

nodeSleeping = true;
logPrintln("Node Sleeping");
}

/* WAKE COMMAND */

else if(type == MSG_WAKE){

nodeSleeping = false;
logPrintln("Node Awake");
}

}

/* INPUT HANDLING */

void readInput(){

if(nodeSleeping) return;

/* BLUETOOTH INPUT */

while(BT.available()){

char c = BT.read();

if(c == '\n' || c == '\r'){

if(inputString.length() > 0){

sendMessage(inputString);
inputString = "";

}

}
else{
inputString += c;
}

}

/* SERIAL INPUT */

while(Serial.available()){

char c = Serial.read();

if(c == '\n' || c == '\r'){

if(inputString.length() > 0){

sendMessage(inputString);
inputString = "";

}

}
else{
inputString += c;
}

}

}

/* CHECK ACK TIMEOUT */

void checkTimeout(){

if(waitingAck && millis() - sendTime > 4000){

waitingAck = false;

if(masterOnline){

masterOnline = false;

logPrintln("⚠ Node not in range. Try again later.");

}

}

}

/* LOOP */

void loop(){

receiveMessage();

readInput();

checkTimeout();

}
